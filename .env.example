# ── Appwrite ──────────────────────────────────────────────────────────────────
# Get these from your Appwrite console → project settings
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_server_api_key_here

# An existing database to provision collections into.
# Create one in the Appwrite console first, then paste its ID here.
APPWRITE_DATABASE_ID=your_database_id_here

# ── Collection IDs ────────────────────────────────────────────────────────────
# These are filled in automatically after running: python setup_db.py
# Copy the printed output block into this file (or your .env directly).
APPWRITE_COMPANIES_ID=
APPWRITE_STATIONS_ID=
APPWRITE_FUEL_PRICE_HISTORY_ID=
APPWRITE_USERS_ID=
APPWRITE_STATION_MANAGERS_ID=
APPWRITE_CUSTOMERS_ID=
APPWRITE_SITUATION_ID=
APPWRITE_DAILY_REPORTS_ID=
APPWRITE_PAYMENTS_ID=
APPWRITE_FICHE_ID=
APPWRITE_LOANS_ID=
APPWRITE_STOCK_DAILY_ID=
APPWRITE_STOCK_ID=
APPWRITE_GAIN_POMPISTE_ID=
APPWRITE_DEVICES_ID=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS=https://boaziza.github.io,http://localhost:3000
